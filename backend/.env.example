# Application
APP_NAME=InkVision AI Backend
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/inkvision_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/inkvision_db

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=png,jpg,jpeg,webp

# Security (for future auth)
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
